# ===== Bolão da Copa — variáveis de ambiente =====
# Copie este arquivo para .env e preencha com os valores reais.

# String de conexão do Supabase (use o CONNECTION POOLER, porta 6543, modo transaction)
# Ex: postgresql+psycopg://postgres.<ref>:<senha>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+psycopg://postgres.xxxx:senha@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# Segredo para assinar o cookie de sessão (gere um valor aleatório longo)
# Ex (PowerShell): python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=troque-por-um-valor-aleatorio-longo

# Credenciais do OAuth do Google (Google Cloud Console > APIs e Serviços > Credenciais)
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-client-secret

# E-mails de administradores, separados por vírgula
ADMIN_EMAILS=marinabpassos@gmail.com

# URL base do site (sem barra no final). Local: http://localhost:8000
BASE_URL=http://localhost:8000
